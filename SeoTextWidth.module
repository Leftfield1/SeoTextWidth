<?php namespace ProcessWire;

/**
 * SEO text width helper for ProcessWire page editor fields.
 */
class SeoTextWidth extends WireData implements Module, ConfigurableModule {

    const VERSION = 9;

    protected $defaults = [
        'seoField' => '',
        'descField' => '',
        'titleMinPx' => 200,
        'titleMaxPx' => 580,
        'descriptionMinPx' => 400,
        'descriptionMaxPx' => 920,
    ];

    public static function getModuleInfo() {
        return [
            'title' => 'SEO Text Width',
            'summary' => 'Shows SEO title and description pixel-width guidance in the ProcessWire page editor, including multilingual fields.',
            'author' => 'Leftfield',
            'href' => 'https://vujosevic.com',
            'version' => self::VERSION,
            'autoload' => true,
            'singular' => true,
            'icon' => 'text-width',
            'requires' => 'ProcessWire>=3.0.0',
        ];
    }

    public function init() {
        $this->addHookAfter('ProcessPageEdit::buildForm', $this, 'addResources');
    }

    public function getModuleConfigInputfields($inputfields) {
        if (!$inputfields instanceof InputfieldWrapper) {
            $inputfields = new InputfieldWrapper();
        }

        $data = array_merge($this->defaults, (array) $this->wire('modules')->getConfig($this->className(false)));
        $options = ['' => 'Select field'] + $this->textFieldOptions();

        $seo = $this->wire('modules')->get('InputfieldSelect');
        $seo->attr('name', 'seoField');
        $seo->label = 'SEO title field';
        $seo->description = 'Select the text or textarea field used for the SEO title.';
        $seo->required = true;
        $seo->addOptions($options);
        $seo->value = $data['seoField'];
        $inputfields->add($seo);

        $desc = $this->wire('modules')->get('InputfieldSelect');
        $desc->attr('name', 'descField');
        $desc->label = 'SEO description field';
        $desc->description = 'Select the text or textarea field used for the SEO meta description.';
        $desc->required = true;
        $desc->addOptions($options);
        $desc->value = $data['descField'];
        $inputfields->add($desc);

        $this->addIntegerField($inputfields, 'titleMinPx', 'SEO title minimum width, px', $data['titleMinPx'], 0, 50);
        $this->addIntegerField($inputfields, 'titleMaxPx', 'SEO title maximum width, px', $data['titleMaxPx'], 1, 50);
        $this->addIntegerField($inputfields, 'descriptionMinPx', 'SEO description minimum width, px', $data['descriptionMinPx'], 0, 50);
        $this->addIntegerField($inputfields, 'descriptionMaxPx', 'SEO description maximum width, px', $data['descriptionMaxPx'], 1, 50);

        $note = $this->wire('modules')->get('InputfieldMarkup');
        $note->label = 'How it works';
        $note->value = '<p>The module measures rendered text width in pixels, not only character count. It adds a status card below every matching language input: <strong>Too short</strong>, <strong>Good length</strong>, or <strong>Too long</strong>.</p>';
        $inputfields->add($note);

        return $inputfields;
    }

    protected function addIntegerField(InputfieldWrapper $inputfields, string $name, string $label, $value, int $min, int $columnWidth): void {
        $field = $this->wire('modules')->get('InputfieldInteger');
        $field->attr('name', $name);
        $field->label = $label;
        $field->value = (int) $value;
        $field->min = $min;
        $field->columnWidth = $columnWidth;
        $inputfields->add($field);
    }

    protected function textFieldOptions(): array {
        $options = [];
        foreach ($this->wire('fields') as $field) {
            if (!$field instanceof Field || !$field->id || !$field->type) {
                continue;
            }

            $type = $field->type->className();
            if (
                strpos($type, 'FieldtypeText') !== 0 &&
                strpos($type, 'FieldtypeTextarea') !== 0 &&
                $type !== 'FieldtypePageTitle' &&
                $type !== 'FieldtypePageTitleLanguage'
            ) {
                continue;
            }

            $label = trim((string) $field->label) ?: $field->name;
            $options[$field->name] = $label . ' (' . $field->name . ')';
        }

        ksort($options);
        return $options;
    }

    public function addResources(HookEvent $event): void {
        $data = array_merge($this->defaults, (array) $this->wire('modules')->getConfig($this->className(false)));
        $seoField = $this->wire('sanitizer')->fieldName((string) $data['seoField']);
        $descField = $this->wire('sanitizer')->fieldName((string) $data['descField']);
        $titleRange = $this->widthRange($data['titleMinPx'], $data['titleMaxPx']);
        $descriptionRange = $this->widthRange($data['descriptionMinPx'], $data['descriptionMaxPx']);

        if ($seoField === '' && $descField === '') {
            return;
        }

        $fields = [];
        if ($seoField !== '') {
            $fields[] = [
                'name' => $seoField,
                'label' => 'SEO title',
                'kind' => 'title',
                'minWidth' => $titleRange['min'],
                'maxWidth' => $titleRange['max'],
                'font' => ['size' => '20px', 'weight' => '400', 'family' => 'Arial, sans-serif'],
            ];
        }

        if ($descField !== '') {
            $fields[] = [
                'name' => $descField,
                'label' => 'SEO description',
                'kind' => 'description',
                'minWidth' => $descriptionRange['min'],
                'maxWidth' => $descriptionRange['max'],
                'font' => ['size' => '13px', 'weight' => '400', 'family' => 'Arial, sans-serif'],
            ];
        }

        $this->wire('config')->js('SeoTextWidth', [
            'fields' => $fields,
            'messages' => [
                'empty' => 'Start typing to measure SEO width.',
                'tooShort' => 'Too short',
                'good' => 'Good length',
                'tooLong' => 'Too long',
                'pixels' => 'px',
                'characters' => 'characters',
                'recommended' => 'Recommended',
            ],
        ]);

        $baseUrl = $this->wire('config')->urls->SeoTextWidth;
        $this->wire('config')->styles->add($baseUrl . 'SeoTextWidth.css?v=' . self::VERSION);
        $this->wire('config')->scripts->add($baseUrl . 'SeoTextWidth.js?v=' . self::VERSION);
    }

    protected function widthRange($min, $max): array {
        $min = max(0, (int) $min);
        $max = max(1, (int) $max);

        if ($min > $max) {
            $swap = $min;
            $min = $max;
            $max = $swap;
        }

        return ['min' => $min, 'max' => $max];
    }
}
